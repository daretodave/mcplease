# Public, RLS-safe config — these ship in the client bundle by design (the anon key is protected by
# row-level security; the sitekey + measurement id are public). The SECRETS (the Supabase service-role
# key, the Turnstile secret) never live here — they're set on the Cloudflare Pages project and read only
# by the edge create function.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key — public by design>

# Cloudflare Turnstile widget sitekey (guards the create form).
VITE_TURNSTILE_SITEKEY=

# GA4 measurement id (G-…). Set ONLY in the production build so dev / preview / hermetic E2E never
# beacon; empty keeps analytics off. Consent defaults to denied regardless.
VITE_GA4_MEASUREMENT_ID=
