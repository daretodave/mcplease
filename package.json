{
  "name": "@mcplease/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "jsdom": "26.1.0",
    "vite": "5.4.21"
  },
  "scripts": {
    "prepare": "lefthook install && npm run codegen -w @mcplease/web",
    "dev": "npm run dev -w @mcplease/web",
    "build": "npm run build -ws --if-present",
    "typecheck": "tsc --noEmit && npm run typecheck -ws --if-present",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage && npm test -ws --if-present",
    "test:structure": "tsx scripts/check-colocated-tests.ts",
    "test:agnostic-seam": "tsx scripts/check-agnostic-seam.ts",
    "test:bundle-budget": "tsx scripts/check-bundle-budget.ts",
    "e2e": "npm run e2e -w @mcplease/web",
    "gen:types": "npm run gen:types -w @mcplease/model",
    "preview": "npm run preview -w @mcplease/web"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "lefthook": "2.1.9",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vitest": "3.2.6"
  }
}
